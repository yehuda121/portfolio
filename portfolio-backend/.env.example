# Local development — copy to .env and fill in your values.

PORT=5000
ALLOWED_ORIGINS=http://localhost:3000

# DynamoDB
AWS_REGION_DB=eu-north-1
SNAKE_BEST_SCORE_TABLE=snake_bestScore
QUIZ_USER_STATS_TABLE=quizUserStats
QUIZ_QUESTIONS_TABLE=quizQuestions

# Quiz admin (backend only — never expose to the frontend)
QUIZ_ADMIN_PASSWORD=change-me

# Model Chat (optional — required only for /api/quiz/admin/character-chat)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# AWS credentials for local DynamoDB access (optional if using ~/.aws profile)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=optional-session-token
