# Optional Docker Compose overrides.
# Usage:
#   1. Copy AWS credentials into your shell OR into portfolio-backend/.env
#   2. docker compose up --build
#
# Snake and Quiz require DynamoDB access. Provide credentials using ONE of:
#   A) Host AWS CLI profile mounted at %USERPROFILE%\.aws (default in docker-compose.yml)
#   B) Environment variables below (set in PowerShell before compose, or in portfolio-backend/.env)

AWS_REGION_DB=eu-north-1
SNAKE_BEST_SCORE_TABLE=snake_bestScore
QUIZ_USER_STATS_TABLE=quizUserStats
QUIZ_QUESTIONS_TABLE=quizQuestions

# Option B — explicit credentials (do not commit real values):
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=optional-session-token

# Quiz admin password (set in portfolio-backend/.env, not here in production):
# QUIZ_ADMIN_PASSWORD=change-me
