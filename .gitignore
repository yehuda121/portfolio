# =============================================================================
# Portfolio monorepo — root .gitignore
# (frontend: portfolio-frontend/ | backend: portfolio-backend/)
# =============================================================================

# --- Dependencies ---
node_modules/

# --- Environment variables (keep *.example tracked) ---
.env
.env.*
!.env.example
!**/.env.example
docker-compose.env
!docker-compose.env.example

# --- Secrets & credentials ---
serviceAccountKey.json
**/serviceAccountKey.json
*firebase-adminsdk*.json
*adminsdk*
serviceAccount*

# --- Frontend build & test output (Create React App) ---
portfolio-frontend/build/
portfolio-frontend/coverage/

# --- Firebase CLI cache ---
.firebase/
**/.firebase/

# --- Backend / Lambda deploy artifacts ---
function.zip
lambda.zip

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Tooling caches ---
.eslintcache
.pnp
.pnp.js
.nyc_output/

# --- Docker local overrides ---
docker-compose.override.yml
**/docker-compose.override.yml

# --- OS files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- IDE / editor ---
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# --- Cursor ---
.cursor/
